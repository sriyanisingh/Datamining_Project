# 4. Clustering (Trend Detection)
from sklearn.cluster import KMeans, DBSCAN
from sklearn.preprocessing import StandardScaler

features_for_clustering = ['Total_Skill_Score', 'Practical_Experience', 'Academic_Consistency']
X_cluster = df[features_for_clustering]

# Scale for distance-based clustering
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X_cluster)

# KMeans
kmeans = KMeans(n_clusters=3, random_state=42)
df['Cluster_KMeans'] = kmeans.fit_predict(X_scaled)

# DBSCAN (Downsampled for performance to avoid taking too much RAM on local machines)
sample_idx = np.random.choice(df.index, min(5000, len(df)), replace=False)
X_dbscan_scaled = X_scaled[sample_idx]
dbscan = DBSCAN(eps=0.5, min_samples=10)
dbscan_labels = dbscan.fit_predict(X_dbscan_scaled)

print('K-Means Cluster Distribution:')
print(df['Cluster_KMeans'].value_counts())
